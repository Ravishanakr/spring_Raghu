<!doctype html>
<html lang="en" xmlns:th="https://www.org.thymeleaf">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Bootstrap demo</title>
<link
	href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
	rel="stylesheet"
	integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
	crossorigin="anonymous">
</head>
<body>



	<div class="container mt-5">


		<div color=green th:text="${Message}"></div>
		
		<h3 class="mt-3">Enter details</h3>


		<form th:action="@{/saveuser}" th:object="${Emp}" method="post">
			<table>

				<tr>
					<td>Employee Name</td>
					<td><input type="text" th:field="*{userName}"></td>
				</tr>

				<tr>
					<td>Employee Email</td>
					<td><input type="text" th:field="*{userEmail}"></td>
				</tr>

				<tr>
					<td>Employee Password</td>
					<td><input type="password" th:field="*{pwd}"></td>
				</tr>


				<tr>
					<td>Employee Roles</td>

					<td><input type="radio" value="ADMIN" th:field="*{userRoles}"
						class="btn btn-primary"></td>

					<td><input type="radio" value="CUTOMER"
						th:field="*{userRoles}" class="btn btn-primary"></td>

				</tr>

				<tr>

				</tr>


			</table>



		</form>


		
	</div>


	<script
		src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
		integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
		crossorigin="anonymous"></script>
</body>
</html>